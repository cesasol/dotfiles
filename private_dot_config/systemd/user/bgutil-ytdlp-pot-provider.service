[Unit]
Description="Proof of context provider for yt-dlp"

[Service]
Type=simple
ExecStart=deno run --allow-env --allow-net --allow-ffi=. --allow-read=. ../src/main.ts
Restart=on-failure
RestartSec=5s
WorkingDirectory=%h/src/github.com/Brainicism/bgutil-ytdlp-pot-provider/server/node_modules

[Install]
WantedBy=default.target
