{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6",
      "variant": "max",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/glm-5.1" },
        { "model": "opencode-go/qwen3.6-plus" },
        { "model": "opencode-go/kimi-k2.5" },
        { "model": "opencode-go/minimax-m2.7" }
      ],
      "ultrawork": {
        "model": "opencode-go/kimi-k2.6"
      },
      "prompt_append": "Always consult prometheus and atlas for planning. Never rush to implementation."
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "prompt_append": "Follow established plans precisely. Ask for clarification when plans are ambiguous.",
      "fallback_models": [
        { "model": "openai/gpt-5.4" },
        { "model": "openai/gpt-5.3-codex" },
        { "model": "opencode-go/deepseek-v4-pro" },
        { "model": "opencode-go/glm-5.1" }
      ]
    },
    "oracle": {
      "model": "opencode-go/glm-5.1",
      "variant": "high",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "librarian": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": [
        { "model": "google/gemini-3.5-flash" },
        { "model": "opencode-go/minimax-m2.7" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "explore": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": [
        { "model": "google/gemini-3.5-flash" },
        { "model": "opencode-go/minimax-m2.7" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "multimodal-looker": {
      "_comment": "Gemini is the native vision model — best for screenshots and visual analysis.",
      "model": "google/gemini-3.1-pro-preview",
      "variant": "medium",
      "fallback_models": [
        { "model": "google/gemini-3-pro-preview", "variant": "medium" },
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "kimi-for-coding/k2p6" },
        { "model": "opencode-go/qwen3.6-plus" },
        { "model": "opencode-go/glm-5.1" }
      ]
    },
    "prometheus": {
      "model": "opencode-go/kimi-k2.6",
      "variant": "high",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/glm-5.1" },
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "opencode-go/qwen3.6-plus" }
      ],
      "prompt_append": "Interview extensively. Question assumptions. Build exhaustive plans with milestones, risks, and contingencies. Use deep & quick agents heavily in parallel for research."
    },
    "metis": {
      "model": "opencode-go/glm-5.1",
      "variant": "high",
      "fallback_models": [
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" }
      ],
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements. Be thorough."
    },
    "momus": {
      "model": "opencode-go/glm-5.1",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" }
      ],
      "prompt_append": "Challenge all assumptions in plans. Look for edge cases, failure modes, and overlooked requirements."
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/glm-5.1" },
        { "model": "opencode-go/minimax-m2.7" },
        { "model": "opencode-go/qwen3.6-plus" }
      ],
      "prompt_append": "Preserve context across long planning sessions. Track evolving decisions."
    },
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/glm-5.1" },
        { "model": "opencode-go/minimax-m2.7" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "_comment": "Gemini is the #1 model for UI/UX, CSS, and design. Qwen is the fallback alternative.",
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        { "model": "google/gemini-3-pro-preview", "variant": "high" },
        { "model": "opencode-go/qwen3.6-plus", "variant": "max" },
        { "model": "opencode-go/glm-5.1" },
        { "model": "opencode-go/kimi-k2.6" }
      ]
    },
    "ultrabrain": {
      "model": "opencode-go/glm-5.1",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "deep": {
      "_comment": "GPT-native category. GLM-5.1 is the best available substitute for autonomous deep work.",
      "model": "opencode-go/glm-5.1",
      "variant": "high",
      "fallback_models": [
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "artistry": {
      "_comment": "Gemini excels at creative and unconventional approaches.",
      "model": "google/gemini-3.1-pro-preview",
      "variant": "max",
      "fallback_models": [
        { "model": "google/gemini-3-pro-preview", "variant": "high" },
        { "model": "opencode-go/qwen3.6-plus", "variant": "max" },
        { "model": "opencode-go/kimi-k2.6" },
        { "model": "opencode-go/glm-5.1" }
      ]
    },
    "quick": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        { "model": "google/gemini-2.5-flash-lite" },
        { "model": "opencode-go/qwen3.5-plus" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "unspecified-low": {
      "model": "opencode-go/kimi-k2.6",
      "variant": "medium",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" },
        { "model": "opencode-go/minimax-m2.7" },
        { "model": "opencode-go/qwen3.5-plus" }
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/kimi-k2.6",
      "variant": "high",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/glm-5.1" },
        { "model": "google/gemini-3.1-pro-preview", "variant": "high" },
        { "model": "opencode-go/qwen3.6-plus" }
      ]
    },
    "writing": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        { "model": "kimi-for-coding/k2p6" },
        { "model": "kimi-for-coding/k2p5" },
        { "model": "opencode-go/qwen3.6-plus" },
        { "model": "opencode-go/minimax-m2.7" },
        { "model": "opencode-go/qwen3.5-plus" }
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 300000,
    "providerConcurrency": {
      "openai": 2,
      "opencode-go": 10,
      "kimi-for-coding": 5,
      "google": 5
    },
    "modelConcurrency": {
      "openai/gpt-5.5": 1
    }
  },
  "experimental": {
    "aggressive_truncation": false,
    "disable_omo_env": true,
    "task_system": false,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ]
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  }
}
