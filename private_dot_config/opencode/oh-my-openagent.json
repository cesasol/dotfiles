{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6",
      "ultrawork": {
        "model": "opencode-go/kimi-k2.6"
      },
      "prompt_append": "Always consult prometheus and atlas for planning. Never rush to implementation.",
      "fallback_models": [
        {
          "model": "kimi-for-coding/k2p6"
        },
        {
          "model": "kimi-for-coding/k2p5"
        },
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "opencode/big-pickle"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "prompt_append": "Follow established plans precisely. Ask for clarification when plans are ambiguous.",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4"
        },
        {
          "model": "openai/gpt-5.3-codex"
        }
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 160000
      },
      "prompt_append": "Interview extensively. Question assumptions. Build exhaustive plans with milestones, risks, and contingencies. Use deep & quick agents heavily in parallel for research.",
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 120000
      },
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        {
          "model": "opencode-go/qwen3.5-plus"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "openai/gpt-5.4-mini"
        },
        {
          "model": "anthropic/claude-haiku-4-5"
        }
      ]
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        {
          "model": "opencode-go/qwen3.5-plus"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "openai/gpt-5.4-mini"
        },
        {
          "model": "anthropic/claude-haiku-4-5"
        }
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.6"
        },
        {
          "model": "kimi-for-coding/k2p6"
        },
        {
          "model": "opencode-go/glm-5"
        },
        {
          "model": "openai/gpt-5.4-mini"
        }
      ]
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements. Be thorough.",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "high"
        },
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "kimi-for-coding/k2p5"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "prompt_append": "Challenge all assumptions in plans. Look for edge cases, failure modes, and overlooked requirements.",
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
"atlas": {
      "model": "opencode-go/kimi-k2.6",
      "prompt_append": "Preserve context across long planning sessions. Track evolving decisions.",
      "fallback_models": [
        {
          "model": "kimi-for-coding/k2p6"
        },
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "anthropic/claude-sonnet-4-6"
        }
      ]
    },
"sisyphus-junior": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        {
          "model": "kimi-for-coding/k2p6"
        },
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "opencode/big-pickle"
        },
        {
          "model": "anthropic/claude-sonnet-4-6"
        }
      ]
    }
  },
  "categories": {
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "opencode/gpt-5-nano"
        },
        {
          "model": "anthropic/claude-haiku-4-5"
        }
      ]
    },
"unspecified-low": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.6"
        },
        {
          "model": "kimi-for-coding/k2p6"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "anthropic/claude-sonnet-4-6"
        }
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "kimi-for-coding/k2p5"
        },
        {
          "model": "opencode-go/kimi-k2.5"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
"writing": {
      "model": "kimi-for-coding/k2p5",
      "fallback_models": [
        {
          "model": "opencode-go/kimi-k2.6"
        },
        {
          "model": "kimi-for-coding/k2p6"
        },
        {
          "model": "opencode-go/minimax-m2.7"
        },
        {
          "model": "anthropic/claude-sonnet-4-6"
        }
      ]
    },
    "visual-engineering": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": [
        {
          "model": "opencode-go/qwen3.6-plus"
        },
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "kimi-for-coding/k2p5"
        }
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 300000,
      "providerConcurrency": {
        "anthropic": 3,
        "openai": 3,
        "opencode-go": 10,
        "kimi-for-coding": 5
      },
    "modelConcurrency": {
      "anthropic/claude-opus-4-7": 2,
      "openai/gpt-5.5": 2
    }
  },
  "experimental": {
    "aggressive_truncation": false,
    "disable_omo_env": true,
    "task_system": false,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ]
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  }
}
